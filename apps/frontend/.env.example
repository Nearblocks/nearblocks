API_ACCESS_KEY=
API_URL=
AWS_REGION=
AWS_SES_FROM_EMAIL=
AWS_SES_TO_EMAIL=
TURNSTILE_SECRET_KEY=

# Server-only FastNear key used solely by the RSC FT REST call
# (src/data/address). Never bundled to the browser. Replaces the old
# NEXT_PUBLIC_FASTNEAR_RPC_KEY.
FASTNEAR_RPC_KEY=

NEXT_PUBLIC_LEGACY_UI_URL=
NEXT_PUBLIC_NETWORK_ID=
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Public origin of apps/api. The browser builds the keyless RPC proxy endpoints
# from it (${NEXT_PUBLIC_API_URL}/v1/rpc, /v1/rpc/archival, /v1/rpc/session).
# Do NOT include a trailing /v1 — the path is appended by the client.
NEXT_PUBLIC_API_URL=

# Phase-2 Turnstile session gate flag ('true' | 'false'). Default false keeps
# Phase-1 behavior (no session minting or gating).
NEXT_PUBLIC_RPC_SESSION_ENFORCED=false
