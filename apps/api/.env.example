# apps/api environment example.
#
# This file documents the variables introduced for the keyless FastNear RPC
# proxy and the optional Turnstile session gate. The full deployment templates
# live at the repo root (mainnet.api.env.example / testnet.api.env.example);
# the variables below must also be present there in production.

# --- RPC proxy (Phase 1) ---

# FastNear API key. SERVER-ONLY. Appended as ?apiKey=... when the proxy forwards
# JSON-RPC to FastNear. Never exposed to the browser, never logged.
FASTNEAR_RPC_KEY=

# FastNear RPC endpoints the proxy forwards to. Optional — sensible
# network-aware defaults are applied when unset (mainnet vs testnet).
# FASTNEAR_RPC_URL=https://rpc.mainnet.fastnear.com
# FASTNEAR_ARCHIVAL_RPC_URL=https://archival-rpc.mainnet.fastnear.com

# Comma-separated Origin allowlist enforced on the proxy routes. Leave empty to
# disable the origin check (open proxy). Example:
# RPC_ALLOWED_ORIGINS=https://example.com,https://www.example.com
RPC_ALLOWED_ORIGINS=

# Dedicated per-IP rate limit for the anonymous proxy (separate from the API
# plan limiter). Generous by design: one pageview fans out into many view calls
# and shared NAT/CGNAT IPs carry many users. Defaults: 1000 requests / 60s.
# RPC_RATELIMIT_POINTS=1000
# RPC_RATELIMIT_DURATION=60

# --- RPC session gate (Phase 2, optional) ---

# Feature flag. When false (default) the session middleware is a no-op and the
# proxy behaves exactly as Phase 1.
RPC_SESSION_ENFORCED=false

# Cloudflare Turnstile secret used to verify session-mint tokens.
TURNSTILE_SECRET_KEY=

# HMAC secret used to sign/verify the short-lived (~30 min) session credential.
RPC_SESSION_SECRET=
