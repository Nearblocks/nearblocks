  "type": "module",
  "imports": {
    "#*": [
      "./dist/*.js"
    ]
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "yarn clean && tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "lint": "tsc --noEmit && eslint ./ --fix",
    "lint:check": "tsc --noEmit && eslint ./"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.749.0",
    "envalid": "8.0.0",
    "express": "4.21.2",
    "prom-client": "15.1.3",
    "uuid": "11.0.3"
  },
  "devDependencies": {
    "@types/express": "~4.17",
    "@types/node": "~20.8",
    "@types/uuid": "~10.0",
    "nb-logger": "*",
    "nb-tsconfig": "*",
    "rimraf": "~5.0",
    "tsx": "~4.20.3",
    "typescript": "~5.2"
  }
}
