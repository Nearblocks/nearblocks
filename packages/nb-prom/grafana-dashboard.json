{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Fleet Status",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Sync Lag",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "time() - max by (indexer) (indexer_last_block_timestamp_seconds{network=~\"$network\", indexer=~\"$indexer\"})",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{indexer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Fleet Overview",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Sync Lag" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 120 },
                    { "color": "orange", "value": 300 },
                    { "color": "red", "value": 600 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors (1h)" },
            "properties": [
              { "id": "decimals", "value": 0 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Block Height" },
            "properties": [{ "id": "decimals", "value": 0 }]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Processing Time p95" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Blocks/sec" },
            "properties": [{ "id": "decimals", "value": 2 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Sync Lag", "desc": true }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "indexer": "Indexer",
              "Value #A": "Block Height",
              "Value #B": "Sync Lag",
              "Value #C": "Blocks/sec",
              "Value #D": "Processing Time p95",
              "Value #E": "Uptime",
              "Value #F": "Errors (1h)"
            },
            "indexByName": {
              "Indexer": 0,
              "Block Height": 1,
              "Sync Lag": 2,
              "Blocks/sec": 3,
              "Processing Time p95": 4,
              "Uptime": 5,
              "Errors (1h)": 6
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (indexer) (indexer_block_height{network=~\"$network\", indexer=~\"$indexer\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "time() - max by (indexer) (indexer_last_block_timestamp_seconds{network=~\"$network\", indexer=~\"$indexer\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (indexer) (rate(indexer_blocks_processed_total{network=~\"$network\", indexer=~\"$indexer\"}[5m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, indexer) (rate(indexer_block_processing_seconds_bucket{network=~\"$network\", indexer=~\"$indexer\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max by (indexer) (indexer_uptime_seconds{network=~\"$network\", indexer=~\"$indexer\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (indexer) (increase(indexer_errors_total{network=~\"$network\", indexer=~\"$indexer\"}[1h]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "F"
        }
      ]
    },
