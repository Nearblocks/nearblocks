FASTNEAR_RPC_URL=
FASTNEAR_ARCHIVAL_RPC_URL=
RPC_ALLOWED_ORIGINS=
# Dedicated per-IP proxy rate limit (defaults: 1000 requests / 60s).
RPC_RATELIMIT_POINTS=1000
RPC_RATELIMIT_DURATION=60

# RPC session gate (Phase 2). Off by default == Phase-1 behaviour.
RPC_SESSION_ENFORCED=false
TURNSTILE_SECRET_KEY=
RPC_SESSION_SECRET=